@model proekt.Data.Cart

@{
    ViewData["Title"] = "Index";
}

<h2>Your Cart</h2>

<table class="table">
    <thead>
        <tr>
            <th>Product</th>
            <th>Quantity</th>
            <th>Price</th>
            <th>Total</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.CartItems != null)
        {
            foreach (var item in Model.CartItems)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.Product.Price</td>
                    <td>@(item.Quantity* item.Product.Price)</td>
                    <td>
                        <a asp-action="Increase" asp-route-id="@item.Id">+</a>
                        <a asp-action="Decrease" asp-route-id="@item.Id">-</a>
                        <a asp-action="Remove" asp-route-id="@item.Id">Remove</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<form asp-controller="Orders" asp-action="Checkout" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-success">Checkout</button>
</form>
